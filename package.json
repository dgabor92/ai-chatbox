{
  "name": "interview-assistant",
  "private": true,
  "main": "electron.js",
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix renderer",
    "dev:llmproxy": "npm run dev --prefix main",
    "dev:electron": "electron .",
    "start": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:llmproxy\" \"wait-on http://localhost:5173 && npm run dev:electron\""
  },
  "devDependencies": {
    "concurrently": "^8.0.1",
    "electron": "^37.2.6",
    "wait-on": "^8.0.4"
  },
  "dependencies": {
    "axios": "^1.11.0",
    "lucide-react": "^0.536.0",
    "screenshot-desktop": "^1.15.1"
  }
}
